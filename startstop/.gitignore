# RubyMine IDE files
.idea/

# PDF file (source document - keep out of version control)
*.pdf

# Generated output files (optional - comment out if you want to track these)
# startstop.html

# Lib folder - track configuration files but exclude generated/debug files
lib/pdf_raw_text.json
lib/pdf_raw_text.txt
lib/startstop_debug.json

# Ruby cache
*.rbc
*.rbx

# Temporary files
*.tmp
*.temp
.DS_Store
Thumbs.db

# Lib temp files
lib/*.tmp
lib/*.bak
